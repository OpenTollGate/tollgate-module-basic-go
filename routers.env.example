# Router Access Configuration
# Copy this file to routers.env and fill in your values.
#   cp routers.env.example routers.env
#
# routers.env is gitignored — credentials never leave your machine.
#
# SSH key auth is preferred. Add your public key to the router:
#   ssh-copy-id root@<router-ip>
#
# For NetBird networks, use the NetBird-assigned IP (typically 100.x.x.x).

# Router SSH user (OpenWrt default is root)
ROUTER_USER ?= root

# SSH options (increase timeout for slow connections)
SSH_OPTS ?= -o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new

# --- Router definitions ---
# Add one line per router. Use the NetBird IP if applicable.
# The ROUTER variable selects which router to target (by name).

ROUTER_ALPHA_HOST=100.64.0.1
ROUTER_ALPHA_LABEL=alpha

ROUTER_BETA_HOST=100.64.0.2
ROUTER_BETA_LABEL=beta
