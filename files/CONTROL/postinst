#!/bin/sh

echo "Running post-installation script"

# Check if /etc/tollgate/install.json exists
if [ -f /etc/tollgate/install.json ]; then
    # Update InstallTimestamp in /etc/tollgate/install.json
    CURRENT_TIMESTAMP=$(date +%s)
    if ! jq ".InstallTimestamp = $CURRENT_TIMESTAMP" /etc/tollgate/install.json > /tmp/install.json.tmp; then
        echo "Error: Failed to update InstallTimestamp using jq" >&2
        exit 1
    fi
    if ! mv /tmp/install.json.tmp /etc/tollgate/install.json; then
        echo "Error: Failed to move temporary file to /etc/tollgate/install.json" >&2
        exit 1
    fi
else
    # Create /etc/tollgate/install.json if it doesn't exist
    mkdir -p /etc/tollgate
    CURRENT_TIMESTAMP=$(date +%s)
    if ! echo "{\"InstallTimestamp\": $CURRENT_TIMESTAMP}" > /etc/tollgate/install.json; then
        echo "Error: Failed to create /etc/tollgate/install.json" >&2
        exit 1
    fi
fi

echo "Verifying banner file ownership:"
ls -l /etc/banner
opkg search /etc/banner
/etc/init.d/tollgate-basic restart
exit 0