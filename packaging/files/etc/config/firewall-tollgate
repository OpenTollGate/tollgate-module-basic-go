config rule
	option name 'Allow-TollGate-In'
	option src 'lan'
	option proto 'tcp'
	option dest_port '2121'
	option target 'ACCEPT'

config zone
	option name 'netbird'
	list device 'wt0'
	option input 'ACCEPT'
